# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=regintel
POSTGRES_PASSWORD=regintel
POSTGRES_DB=regintel
DATABASE_URL=postgresql+asyncpg://regintel:regintel@db:5432/regintel

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── LLM providers ─────────────────────────────────────────────────────────────
# LLM_PROVIDER=random  → stub mode: random embeddings + mock LLM, no API credits needed.
# LLM_PROVIDER=openai  → production: requires funded OPENAI_API_KEY.
# LLM_PROVIDER=anthropic → requires ANTHROPIC_API_KEY (embeddings still use OpenAI).
LLM_PROVIDER=random
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Retrieval ─────────────────────────────────────────────────────────────────
# none (default) | cross-encoder | cohere
RERANKER_BACKEND=none

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=changeme-replace-in-production
LOG_LEVEL=INFO
