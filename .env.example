# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=regintel
POSTGRES_PASSWORD=changeme
POSTGRES_DB=regintel
DATABASE_URL=postgresql+asyncpg://regintel:changeme@db:5432/regintel

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── LLM providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=changeme
LOG_LEVEL=INFO

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
# Override in docker-compose; set to http://localhost:8000 for local dev without Docker
NEXT_PUBLIC_API_URL=http://localhost:8000
