# RegIntel AI example environment.
# Copy to .env for local development. Do not commit real secrets.

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=regintel
POSTGRES_PASSWORD=regintel
POSTGRES_DB=regintel
DATABASE_URL=postgresql+asyncpg://regintel:regintel@db:5432/regintel

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── LLM providers ────────────────────────────────────────────────────────────
# random/mock: local stub mode, no network calls for answer generation.
# openai: requires OPENAI_API_KEY.
# anthropic: requires ANTHROPIC_API_KEY for answers; embeddings still use OpenAI unless code is changed.
LLM_PROVIDER=random
LLM_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=100

# ── Retrieval / reranking ────────────────────────────────────────────────────
# none (default) | cross-encoder | cohere
RERANKER_BACKEND=none
COHERE_API_KEY=

# ── Ingestion ────────────────────────────────────────────────────────────────
UPLOAD_DIR=/data/uploads
INDEX_DIR=/data/indexes
CHUNK_TARGET_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
OCR_TEXT_THRESHOLD=50

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=changeme-replace-in-production
LOG_LEVEL=INFO

# ── Web ──────────────────────────────────────────────────────────────────────
# Server-side Next.js rewrite target. Docker Compose overrides this for containers.
API_URL=http://localhost:8000
